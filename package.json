{
  "name": "@code-guideline/eslint",
  "version": "0.1.19",
  "description": "Code Guideline for eslint",
  "main": "index.js",
  "scripts": {
    "build": "rimraf dist && tsup src/index.mjs",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint . --fix",
    "lint:dry": "eslint . --fix-dry-run",
    "test": "pnpm run build && eslint . --max-warnings 0"
  },
  "keywords": [
    "eslint",
    "code",
    "guideline",
    "generator"
  ],
  "author": {
    "name": "Jeewon Kwon",
    "email": "jeewon.kwon.0817@gmail.com",
    "url": "https://github.com/jwkwon0817"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.13.1+sha512.37ebf1a5c7a30d5fabe0c5df44ee8da4c965ca0c5af3dbab28c3a1681b70a256218d05c81c9c0dcf767ef6b8551eb5b960042b9ed4300c59242336377e01cfad",
  "devDependencies": {
    "eslint": "^10.2.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1"
  },
  "dependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-newlines": "^2.0.0",
    "eslint-plugin-newline-destructuring": "^1.2.2",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1"
  },
  "peerDependencies": {
    "eslint": "^10.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "10"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./src/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jwkwon0817/code-guideline-eslint.git"
  }
}
